{{define "subject"}}Welcome to Ace Closet!{{end}}

{{define "plainBody"}}
Hi,
Please activate your account by visiting the link below:
http://localhost:4000/v1/users/activated?token={{.activationToken}}
{{end}}

{{define "htmlBody"}}
<!doctype html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <style>
        /* Base styles for clients that support them */
        body { background-color: #f6f6f6; font-family: sans-serif; -webkit-font-smoothing: antialiased; font-size: 14px; line-height: 1.4; margin: 0; padding: 0; }
        .container { display: block; margin: 0 auto !important; max-width: 580px; padding: 10px; width: 580px; }
        .content { box-sizing: border-box; display: block; margin: 0 auto; max-width: 580px; padding: 10px; }
        .main { background: #ffffff; border-radius: 8px; width: 100%; border: 1px solid #e9e9e9; }
        .wrapper { box-sizing: border-box; padding: 30px; }
        .btn { box-sizing: border-box; width: 100%; }
        .btn table { width: auto; }
        .btn table td { background-color: #000000; border-radius: 5px; text-align: center; }
        .btn a { background-color: #000000; border: solid 1px #000000; border-radius: 5px; box-sizing: border-box; color: #ffffff; cursor: pointer; display: inline-block; font-size: 14px; font-weight: bold; margin: 0; padding: 12px 25px; text-decoration: none; text-transform: capitalize; }
        .footer { clear: both; margin-top: 10px; text-align: center; width: 100%; }
        .footer td, .footer p, .footer span, .footer a { color: #999999; font-size: 12px; text-align: center; }
    </style>
</head>
<body>
    <table role="presentation" border="0" cellpadding="0" cellspacing="0" class="body">
        <tr>
            <td>&nbsp;</td>
            <td class="container">
                <div class="content">
                    <table role="presentation" class="main">
                        <tr>
                            <td class="wrapper">
                                <table role="presentation" border="0" cellpadding="0" cellspacing="0">
                                    <tr>
                                        <td>
                                            <h1 style="font-size: 24px; font-weight: bold; margin: 0 0 20px; font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;">Welcome to Ace Closet!</h1>
                                            <p style="margin: 0 0 20px;">Hi there,</p>
                                            <p style="margin: 0 0 20px;">Thanks for signing up! We're excited to have you. To get started, please verify your email address by clicking the button below.</p>
                                            <table role="presentation" border="0" cellpadding="0" cellspacing="0" class="btn btn-primary">
                                                <tbody>
                                                    <tr>
                                                        <td align="left">
                                                            <table role="presentation" border="0" cellpadding="0" cellspacing="0">
                                                                <tbody>
                                                                    <tr>
                                                                        <td> <a href="http://localhost:4000/v1/users/activated?token={{.activationToken}}" target="_blank">Verify Email Address</a> </td>
                                                                    </tr>
                                                                </tbody>
                                                            </table>
                                                        </td>
                                                    </tr>
                                                </tbody>
                                            </table>
                                            <p style="margin: 20px 0 0; font-size: 12px; color: #666666;">If you didn't create an account with Ace Closet, you can safely ignore this email.</p>
                                        </td>
                                    </tr>
                                </table>
                            </td>
                        </tr>
                    </table>
                    <div class="footer">
                        <table role="presentation" border="0" cellpadding="0" cellspacing="0">
                            <tr>
                                <td class="content-block">
                                    <span class="apple-link">Ace Closet, Belmopan, Belize</span>
                                </td>
                            </tr>
                        </table>
                    </div>
                </div>
            </td>
            <td>&nbsp;</td>
        </tr>
    </table>
</body>
</html>
{{end}}